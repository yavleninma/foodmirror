# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_here

# === OpenAI ===
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# === Database ===
# Локально: PostgreSQL на своей машине или в Docker (см. ниже)
# Railway: DATABASE_URL подтягивается автоматически из PostgreSQL сервиса
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foodmirror

# === Server ===
PORT=3000
NODE_ENV=development

# === Local dev Telegram mock (API, development only) ===
# Set to 1 to allow X-Dev-Telegram-Mock header from local frontend.
DEV_TELEGRAM_MOCK_ENABLED=0
DEV_TELEGRAM_MOCK_USER_ID=900001
DEV_TELEGRAM_MOCK_FIRST_NAME=Local
DEV_TELEGRAM_MOCK_LAST_NAME=
DEV_TELEGRAM_MOCK_USERNAME=local_dev
